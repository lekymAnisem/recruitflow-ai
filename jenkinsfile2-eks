pipeline {
    agent any
    tools {
        jdk 'jdk21'
        nodejs 'node20'
    }
    environment {
        SCANNER_HOME = tool 'sonar-scanner'
    }
    stages {
        stage('clean workspace') {
            steps {
                cleanWs()
            }
        }
        stage('Checkout from Git') {
            steps {
                git branch: 'main', credentialsId: 'github-token', url: 'https://github.com/lekymAnisem/recruitflow-ai.git'
            }
        }
        stage('Sonarqube Analysis') {
            steps {
                withSonarQubeEnv('SonarQube') {
                    sh ''' $SCANNER_HOME/bin/sonar-scanner -Dsonar.projectName=recruitflow-ai \
                    -Dsonar.projectKey=recruitflow-ai '''
                }
            }
        }
        stage('quality gate') {
            steps {
                script {
                    waitForQualityGate abortPipeline: false, credentialsId: 'Sonar-token'
                }
            }
        }
        stage('Install Dependencies') {
            parallel {
                stage('Backend Install') {
                    steps {
                        dir('backend') {
                            sh 'npm install'
                        }
                    }
                }
                stage('Frontend Install') {
                    steps {
                        dir('frontend') {
                            sh 'npm install'
                        }
                    }
                }
            }
        }
        stage('TRIVY FS SCAN') {
            steps {
                sh 'trivy fs . > trivyfs.txt'
            }
        }
        stage('Docker Build & Push') {
            parallel {
                stage('Backend Docker') {
                    steps {
                        dir('backend') {
                            script {
                                withDockerRegistry(credentialsId: 'docker', toolName: 'docker') {
                                    sh 'docker build -t recruitflow-backend .'
                                    sh 'docker tag recruitflow-backend dracoo23/recruitflow-backend:latest'
                                    sh 'docker push dracoo23/recruitflow-backend:latest'
                                }
                            }
                        }
                    }
                }
                stage('Frontend Docker') {
                    steps {
                        dir('frontend') {
                            script {
                                withDockerRegistry(credentialsId: 'docker', toolName: 'docker') {
                                    sh 'docker build -t recruitflow-frontend .'
                                    sh 'docker tag recruitflow-frontend dracoo23/recruitflow-frontend:latest'
                                    sh 'docker push dracoo23/recruitflow-frontend:latest'
                                }
                            }
                        }
                    }
                }
            }
        }
        stage('TRIVY') {
            parallel {
                stage('TRIVY Backend') {
                    steps {
                        sh 'trivy image dracoo23/recruitflow-backend:latest > trivyimage-backend.txt'
                    }
                }
                stage('TRIVY Frontend') {
                    steps {
                        sh 'trivy image dracoo23/recruitflow-frontend:latest > trivyimage-frontend.txt'
                    }
                }
            }
        }
        stage('Deploy to EKS Cluster') {
            steps {
                dir('infra/k8s') {
                    script {
                        sh '''
                            echo "Verifying AWS credentials..."
                            aws sts get-caller-identity

                            echo "Configuring kubectl for EKS cluster..."
                            aws eks update-kubeconfig --region ap-southeast-2 --name Cloudaseem

                            echo "Verifying kubeconfig..."
                            kubectl config view

                            echo "Deploying backend & frontend to EKS..."
                            kubectl apply -f backend-deployment.yaml
                            kubectl apply -f backend-service.yaml
                            kubectl apply -f frontend-deployment.yaml
                            kubectl apply -f frontend-service.yaml
                            kubectl apply -f configmap.yaml

                            echo "Verifying deployment..."
                            kubectl get pods
                            kubectl get svc
                        '''
                    }
                }
            }
        }
    }
    post {
        always {
            script {
                def buildStatus = currentBuild.currentResult
                def buildUser = currentBuild.getBuildCauses('hudson.model.Cause$UserIdCause')[0]?.userId ?: 'Github User'

                emailext(
                    subject: "Pipeline ${buildStatus}: ${env.JOB_NAME} #${env.BUILD_NUMBER}",
                    body: """
                        <p>This is a Jenkins recruitflow-ai CICD pipeline status.</p>
                        <p>Project: ${env.JOB_NAME}</p>
                        <p>Build Number: ${env.BUILD_NUMBER}</p>
                        <p>Build Status: ${buildStatus}</p>
                        <p>Started by: ${buildUser}</p>
                        <p>Build URL: <a href="${env.BUILD_URL}">${env.BUILD_URL}</a></p>
                    """,
                    to: 'silverioedgardo123@gmail.com',
                    from: 'silverioedgardo123@gmail.com',
                    replyTo: 'silverioedgardo123@gmail.com',
                    mimeType: 'text/html',
                    attachmentsPattern: 'trivyfs.txt,trivyimage-backend.txt,trivyimage-frontend.txt'
                )
            }
        }
    }
}
